# Paperwall E2E Test Configuration
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit real keys.

# Reader/client wallet private key (signs payments)
# Use a TESTNET-ONLY key with small USDC balance on SKALE testnet.
PAPERWALL_PRIVATE_KEY=0x_YOUR_TESTNET_PRIVATE_KEY_HERE

# Publisher wallet address (receives payments)
TEST_PAY_TO=0x_YOUR_PUBLISHER_ADDRESS_HERE

# Facilitator URL (default: SKALE testnet gateway)
TEST_FACILITATOR_URL=https://gateway.kobaru.io

# CAIP-2 network identifier (default: SKALE testnet)
TEST_NETWORK=eip155:324705682

# Price in smallest units (USDC has 6 decimals)
# 1 = 0.000001 USDC — cheapest possible, run unlimited tests
TEST_PRICE=1

# A2A server access key for test authentication
TEST_ACCESS_KEY=test-e2e-key-change-me

# ── Multi-Network Config (optional) ──────────────────────────────
# Base Sepolia (testnet) - alternative network
BASE_SEPOLIA_NETWORK=eip155:84532
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# SKALE Mainnet (production) - only use with real funds
# SKALE_MAINNET_NETWORK=eip155:1187947933
# SKALE_MAINNET_USDC=0x85889c8c714505E0c94b30fcfcF64fE3Ac8FCb20

# Base Mainnet (production) - only use with real funds
# BASE_MAINNET_NETWORK=eip155:8453
# BASE_MAINNET_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
